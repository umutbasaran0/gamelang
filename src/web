let G = null; // game state

function propVal(props, key, def=null) {
  const p = props.find(p=>p.key===key);
  return p ? p.val : def;
}

function parseAndBuild() {
  hideError();
  const code = document.getElementById('codeInput').value.trim();
  if (!code) { showError('Kod boş!'); return; }

  let decls;
  try {
    const tokens = tokenize(code);
    const parser = new Parser(tokens);
    decls = parser.parseProgram();
  } catch(e) {
    showError('Sözdizimi Hatası: ' + e.message);
    return;
  }

  // Build game state from declarations
  const arenas   = decls.filter(d=>d.kind==='arena');
  const tiles    = decls.filter(d=>d.kind==='tile');
  const decks    = decls.filter(d=>d.kind==='deck');
  const resources= decls.filter(d=>d.kind==='resource');
  const playersD = decls.find(d=>d.kind==='players');
  const turnStr  = decls.find(d=>d.kind==='turn_structure');
  const events   = decls.filter(d=>d.kind==='event');

  const boardSize= arenas.length>0 ? propVal(arenas[0].props,'size',20) : (tiles.length||20);
  const pCount   = playersD ? propVal(playersD.props,'count',2) : 2;
  const startMoney= playersD ? propVal(playersD.props,'start_money',1500) : 1500;
  const startHp  = playersD ? propVal(playersD.props,'start_hp',100) : 100;

  // Build board tiles array (repeat / cycle tile types)
  const tilePool = tiles.length > 0 ? tiles : [
    {name:'Başlangıç',props:[{key:'type',val:'start'},{key:'color',val:'green'},{key:'bonus',val:200}]},
    {name:'Mülk 1',   props:[{key:'type',val:'property'},{key:'color',val:'blue'},{key:'price',val:200},{key:'rent',val:30}]},
    {name:'Şans',     props:[{key:'type',val:'chance'},{key:'color',val:'yellow'}]},
    {name:'Mülk 2',   props:[{key:'type',val:'property'},{key:'color',val:'red'},{key:'price',val:350},{key:'rent',val:60}]},
  ];

  const board = [];
  for (let i=0; i<boardSize; i++) {
    const base = tilePool[i % tilePool.length];
    board.push({...base, index: i, props:[...base.props]});
  }
  // Ensure first tile is "start"
  if (board.length > 0 && propVal(board[0].props,'type','')!=='start') {
    board[0] = {name:'BAŞLANGIÇ', index:0, props:[{key:'type',val:'start'},{key:'color',val:'green'},{key:'bonus',val:200}]};
  }

  // Players
  const colors = ['#ff6b6b','#6c8bff','#06d6a0','#ffd166','#ff9f43','#a29bfe'];
  const emojis = ['🔴','🔵','🟢','🟡','🟠','🟣'];
  const players = [];
  for (let p=0; p<pCount; p++) {
    players.push({
      id: p, name: `Oyuncu ${p+1}`,
      pos: 0, money: startMoney, hp: startHp,
      color: colors[p%colors.length], emoji: emojis[p%emojis.length],
      alive: true, turnsInJail: 0
    });
  }

  G = {
    board, players, decks, events, resources,
    phases: turnStr ? turnStr.phases : [],
    currentPlayer: 0,
    turn: 1,
    lastRoll: [1,1],
    gameOver: false,
    log: []
  };

  document.getElementById('parseStatus').textContent = `✅ ${boardSize} kare, ${pCount} oyuncu, ${decls.length} bildirim`;
  document.getElementById('statusBadge').textContent = 'Hazır';
  document.getElementById('controlPanel').style.display='block';
  document.getElementById('boardContainer').style.display='block';
  document.getElementById('winnerBanner').style.display='none';

  buildPhaseUI();
  renderBoard();
  renderPlayers();
  renderDecks();
  addLog('Oyun yüklendi ve başladı! 🎲','system');
  addLog(`${boardSize} kare, ${pCount} oyuncu, ${G.phases.length} faz`,'system');
}

function buildPhaseUI() {
  const el = document.getElementById('phaseIndicator');
  el.innerHTML = '';
  if (!G.phases.length) {
    el.innerHTML = '<span class="phase-chip active-phase">Zar At & İlerle</span>';
    return;
