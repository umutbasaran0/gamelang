// ── BOARD RENDER ──
function buildMonopolyGrid(board) {
  const size = board.length;
  // Monopoly-style: tiles around the perimeter of a square
  const side = Math.ceil(size/4); // tiles per side
  const gridSize = side + 2; // total grid dimension (corners take 1 each)
  // positions: bottom row L→R, right col B→T, top row R→L, left col T→B
  const positions = []; // {row, col, tileIdx}
  // bottom row (row = gridSize-1): col 0..gridSize-1
  for (let c=0;c<=gridSize-1&&positions.length<size;c++) positions.push({r:gridSize-1,c});
  // right col (col = gridSize-1): row gridSize-2 down to 0
  for (let r=gridSize-2;r>=0&&positions.length<size;r--) positions.push({r,c:gridSize-1});
  // top row (row = 0): col gridSize-2 down to 0
  for (let c=gridSize-2;c>=0&&positions.length<size;c--) positions.push({r:0,c});
  // left col (col = 0): row 1 to gridSize-2
  for (let r=1;r<=gridSize-2&&positions.length<size;r++) positions.push({r,c:0});

  return {gridSize, positions};
}

function renderBoard() {
  const el = document.getElementById('boardEl');
  if (!G) { el.innerHTML=''; return; }

  const {gridSize, positions} = buildMonopolyGrid(G.board);
  el.style.gridTemplateColumns = `repeat(${gridSize}, var(--tile-w))`;
  el.style.gridTemplateRows    = `repeat(${gridSize}, var(--tile-h))`;

  // clear
  el.innerHTML='';

  // place tiles
  const cells = {}; // "r,c" -> div
  for (let r=0;r<gridSize;r++) for(let c=0;c<gridSize;c++) {
    const div = document.createElement('div');
    div.style.gridRow = `${r+1}`;
    div.style.gridColumn = `${c+1}`;
    div.style.background='transparent';
    el.appendChild(div);
    cells[`${r},${c}`]=div;
  }

  // fill board tiles
  positions.forEach((pos,idx)=>{
    const tile = G.board[idx];
    const div = cells[`${pos.r},${pos.c}`];
    const ttype = propVal(tile.props,'type','normal');
    const color  = propVal(tile.props,'color','#2a3050');
    const price  = propVal(tile.props,'price',null);
    const rent   = propVal(tile.props,'rent',null);
    const bonus  = propVal(tile.props,'bonus',null);

    div.className = `tile tile-${ttype}`;
    if (idx===0) div.classList.add('tile-go');

    const colorBar = document.createElement('div');
    colorBar.className='tile-color-bar';
    colorBar.style.background = colorForTile(ttype, color);
    div.appendChild(colorBar);

    const nm = document.createElement('div');
    nm.className='tile-name';
    nm.textContent = tile.name;
    div.appendChild(nm);

    const tp = document.createElement('div');
    tp.className='tile-type';
    tp.textContent = typeLabel(ttype);
    div.appendChild(tp);

    if (price!==null) {
      const pv=document.createElement('div'); pv.className='tile-val'; pv.textContent=`💰${price}`; div.appendChild(pv);
    } else if (bonus!==null) {
      const pv=document.createElement('div'); pv.className='tile-val'; pv.textContent=`+💰${bonus}`; div.appendChild(pv);
    }
    if (rent!==null) {
      const pv=document.createElement('div'); pv.className='tile-val'; pv.textContent=`🏠${rent}`; div.appendChild(pv);
    }

    // index badge
    const ib=document.createElement('div');
    ib.style.cssText='position:absolute;top:3px;left:4px;font-size:.5rem;color:rgba(255,255,255,.3);font-weight:700';
    ib.textContent=idx;
    div.appendChild(ib);

    // store pos in tile data
    tile._dom = div;
    tile._gridPos = pos;
  });

  // render center area
  const midR = Math.floor(gridSize/2);
  const midC = Math.floor(gridSize/2);
  const center = cells[`${midR},${midC}`];
  if (center) {
    center.style.gridRow = `2 / ${gridSize}`;
    center.style.gridColumn = `2 / ${gridSize}`;
    center.style.background='linear-gradient(135deg,#0f1117,#1a1f35)';
    center.style.border='1px solid #2a3050';
    center.style.borderRadius='8px';
    center.style.display='flex';
    center.style.flexDirection='column';
    center.style.alignItems='center';
    center.style.justifyContent='center';
    center.style.gap='8px';
    center.innerHTML=`
      <div style="font-size:3rem">🎲</div>
      <div style="font-size:.85rem;font-weight:700;color:#6c8bff;text-align:center">OYUN<br>TAHTASI</div>
      <div style="font-size:.7rem;color:#64748b">${G.board.length} kare</div>
    `;
    // Remove other center cells
    for (let r=1;r<gridSize-1;r++) for(let c=1;c<gridSize-1;c++) {
      if (r===midR&&c===midC) continue;
      const cd=cells[`${r},${c}`];
      if (cd && cd.parentNode===el) cd.remove();
    }
  }

  renderTokens();
}

function colorForTile(type, color) {
  const map={start:'#06d6a0',go:'#06d6a0',jail:'#ffd166',chance:'#6c8bff',
             property:'#ff6b6b',normal:'#4a5568'};
  if (color && color.startsWith('#')) return color;
  return map[type]||map[color]||'#4a5568';
}
function typeLabel(type) {
  const map={start:'BAŞLANGIÇ',go:'GEÇ',jail:'HAPİS',chance:'ŞANS',
             property:'MÜLK',normal:'ALAN'};
  return map[type]||(type?type.toUpperCase():'');
}

function renderTokens() {
  // remove old tokens
  document.querySelectorAll('.player-token').forEach(e=>e.remove());
  if (!G) return;

  // Group players by position
  const byPos={};
  G.players.forEach(p=>{ if (!p.alive) return; (byPos[p.pos]||(byPos[p.pos]=[])).push(p); });

  G.board.forEach((tile,idx)=>{
    if (!tile._dom||!byPos[idx]) return;
    const players=byPos[idx];
    players.forEach((pl,j)=>{
      const tok=document.createElement('div');
      tok.className='player-token';
      tok.style.background=pl.color;
      tok.style.right=(4+j*22)+'px';
      tok.textContent=pl.emoji;
      tile._dom.appendChild(tok);
    });
  });
}

