// ── GAME ACTIONS ──
function evalExpr(expr, env) {
  if (!expr) return 0;
  if (expr.type==='INT')    return expr.val;
  if (expr.type==='FLOAT')  return expr.val;
  if (expr.type==='STRING') return expr.val;
  if (expr.type==='BOOL')   return expr.val;
  if (expr.type==='IDENT') {
    if (expr.name in env) return env[expr.name];
    return 0;
  }
  if (expr.type==='UNARY'&&expr.op==='not') return !evalExpr(expr.operand,env);
  if (expr.type==='BINOP') {
    if (expr.op==='and') return evalExpr(expr.left,env) && evalExpr(expr.right,env);
    if (expr.op==='or')  return evalExpr(expr.left,env) || evalExpr(expr.right,env);
    const l=evalExpr(expr.left,env), r=evalExpr(expr.right,env);
    switch(expr.op) {
      case '+': return typeof l==='string'||typeof r==='string' ? ''+l+r : l+r;
      case '-': return l-r; case '*': return l*r;
      case '/': return r===0?0:l/r;
      case '==': return l===r; case '!=': return l!==r;
      case '<': return l<r; case '>': return l>r;
      case '<=': return l<=r; case '>=': return l>=r;
    }
  }
  return 0;
}

function execStmts(stmts, env, player) {
  if (!stmts) return;
  for (const stmt of stmts) {
    execStmt(stmt, env, player);
  }
}

function execBlock(block, env, player) {
  if (!block) return;
  execStmts(block.stmts||[], env, player);
}

function execStmt(stmt, env, player) {
  if (!stmt) return;
  if (stmt.type==='BLOCK') { execBlock(stmt,env,player); return; }
  if (stmt.type==='IF') {
    if (evalExpr(stmt.cond,env)) execBlock(stmt.then,env,player);
    else if (stmt.els) execBlock(stmt.els,env,player);
    return;
  }
  if (stmt.type==='WHILE') {
    let iters=0;
    while (evalExpr(stmt.cond,env)&&iters<1000) { execBlock(stmt.body,env,player); iters++; }
    return;
  }
  if (stmt.type==='ASSIGN') { env[stmt.name]=evalExpr(stmt.expr,env); return; }
  if (stmt.type==='ACTION') {
    const name=stmt.name;
    const args=stmt.args.map(a=>evalExpr(a,env));
    switch(name) {
      case 'heal': {
        const amt=args[0]||0;
        player.hp=Math.min(100,player.hp+amt);
        addLog(`💚 ${player.name} +${amt} can (→${player.hp})`,'heal');
        break;
      }
      case 'damage': {
        const amt=args[0]||0;
        player.hp=Math.max(0,player.hp-amt);
        addLog(`💔 ${player.name} -${amt} can (→${player.hp})`,'damage');
        if (player.hp<=0) { player.alive=false; addLog(`💀 ${player.name} elendi!`,'damage'); }
        break;
      }
      case 'pay': {
        const amt=args[0]||0;
        player.money=Math.max(0,player.money-amt);
        addLog(`💸 ${player.name} -${amt}💰 (→${player.money})`,'damage');
        if (player.money<=0) { player.alive=false; addLog(`💀 ${player.name} iflas etti!`,'damage'); }
        break;
      }
      case 'heal': break; // handled above
      case 'transfer': { const amt=args[0]||0; player.money+=amt; addLog(`💰 ${player.name} +${amt}`,'heal'); break; }
      case 'advance': {
        const steps=Math.round(args[0])||0;
        const oldPos=player.pos;
        player.pos=(player.pos+steps)%G.board.length;
        if (player.pos<oldPos) {
          player.money+=200;
          addLog(`🔄 ${player.name} başa döndü! +200💰`,'heal');
          triggerEvent('pass', {player: player.id*100});
        }
        addLog(`👣 ${player.name} +${steps} kare → kare ${player.pos} (${G.board[player.pos].name})`,'event');
        break;
      }
      case 'move_to': {
        const target=args[0];
        if (typeof target==='number') {
          player.pos=Math.min(G.board.length-1,Math.max(0,target));
        } else {
          const idx=G.board.findIndex(t=>t.name===target||propVal(t.props,'type','')==='jail');
          if (idx>=0) player.pos=idx;
        }
        addLog(`🚀 ${player.name} → ${G.board[player.pos].name}`,'event');
        break;
      }
      case 'roll': {
        const ndice=args[0]||2, sides=args[1]||6;
        let total=0;
        for(let d=0;d<ndice;d++) total+=Math.floor(Math.random()*sides)+1;
        env['result']=total;
        addLog(`🎲 ${player.name} zar: ${total}`,'');
        break;
      }
      case 'random': {
        const lo=args[0]||1,hi=args[1]||6;
        const r=Math.floor(Math.random()*(hi-lo+1))+lo;
        env['result']=r;
        addLog(`🎰 random(${lo}..${hi}) = ${r}`,'');
        break;
      }
      case 'draw': {
        drawCard();
        break;
      }
      case 'eliminate': {
        player.alive=false;
        addLog(`💀 ${player.name} oyundan elendi!`,'damage');
        break;
      }
      case 'print': {
        const msg=args.join('');
        addLog(`📢 ${msg}`,'');
        break;
      }
      case 'end_phase': { addLog('⏭ Faz sona erdi','system'); break; }
      default: addLog(`[${name}] ${args.join(', ')}`,'system');
    }
  }
}

function triggerEvent(eventType, params={}) {
  if (!G) return;
  const ev=G.events.find(e=>e.event_type===eventType);
  if (!ev) return;
  const player=G.players[G.currentPlayer];
  const env={...params, result:G.lastRoll[0]+G.lastRoll[1]};
  // inject params by name
  ev.params.forEach((pname,i)=>{
    env[pname]=Object.values(params)[i]??player.id*100;
  });
  addLog(`⚡ Olay: on ${eventType}`,'event');
  execBlock(ev.body, env, player);
}

function takeTurn() {
  if (!G||G.gameOver) return;
  const player=G.players[G.currentPlayer];
  if (!player.alive) { nextPlayer(); return; }

  addLog(`\n═══ ${player.name} SIRA ═══`,'system');
  document.getElementById('turnLabel').textContent=`Tur ${G.turn} — ${player.name}`;

  // Roll dice
  const d1=Math.floor(Math.random()*6)+1;
  const d2=Math.floor(Math.random()*6)+1;
  G.lastRoll=[d1,d2];
  const total=d1+d2;

  animateDice(d1,d2,total);

  const env={result:total, player:player.id*100};

  // Execute phases
  if (G.phases.length) {
    G.phases.forEach((ph,i)=>{
      updatePhaseUI(i);
      addLog(`▶ Faz: ${ph.name}`,'system');
      execBlock(ph.body, env, player);
    });
    updatePhaseUI(-1);
  } else {
    // Default: roll & advance
    const oldPos=player.pos;
    player.pos=(player.pos+total)%G.board.length;
    if (player.pos<oldPos) {
      player.money+=200;
      addLog(`🔄 ${player.name} başa döndü! +200💰`,'heal');
      triggerEvent('pass',{player:player.id*100});
    }
    addLog(`👣 ${player.name} +${total} → kare ${player.pos} (${G.board[player.pos].name})`,'event');
  }

  // Trigger land event
  triggerEvent('land', {player: player.id*100});

  // Tile effects
  const tile=G.board[player.pos];
  const ttype=propVal(tile.props,'type','normal');
  if (ttype==='chance'&&G.decks.length) {
    setTimeout(()=>drawCard(),300);
  }
  if (ttype==='start'||ttype==='go') {
    const bonus=propVal(tile.props,'bonus',200);
    player.money+=bonus;
    addLog(`🌟 ${player.name} Başlangıç'ta! +${bonus}💰`,'heal');
  }

  renderBoard();
  renderPlayers();
  checkWinLose();

  if (!G.gameOver) {
    setTimeout(()=>nextPlayer(),500);
  }
}

function animateDice(d1,d2,total) {
  const die1=document.getElementById('die1');
  const die2=document.getElementById('die2');
  die1.classList.add('rolling'); die2.classList.add('rolling');
  const faces=['⚀','⚁','⚂','⚃','⚄','⚅'];
  die1.textContent=faces[d1-1];
  die2.textContent=faces[d2-1];
  document.getElementById('diceTotal').textContent=total;
  setTimeout(()=>{die1.classList.remove('rolling');die2.classList.remove('rolling');},400);
}

function nextPlayer() {
  if (!G) return;
  let next=(G.currentPlayer+1)%G.players.length;
  let tries=0;
  while (!G.players[next].alive&&tries<G.players.length) {
    next=(next+1)%G.players.length; tries++;
  }
  G.currentPlayer=next;
  G.turn++;
  renderPlayers();
}

function checkWinLose() {
  if (!G) return;
  const alive=G.players.filter(p=>p.alive);
  if (alive.length===1) {
    G.gameOver=true;
    const winner=alive[0];
    document.getElementById('winnerBanner').style.display='block';
    document.getElementById('winnerText').textContent=`🏆 ${winner.name} kazandı! Para: ${winner.money}💰  Can: ${winner.hp}❤️`;
    addLog(`🏆 OYUN BİTTİ! ${winner.name} kazandı!`,'system');
  }
  if (alive.length===0) {
    G.gameOver=true;
    document.getElementById('winnerBanner').style.display='block';
    document.getElementById('winnerText').textContent='Tüm oyuncular elendi. Beraberlik!';
  }
}

function drawCard() {
  if (!G||!G.decks.length) { addLog('Kart destesi yok','system'); return; }
  const deck=G.decks[Math.floor(Math.random()*G.decks.length)];
  if (!deck.cards||!deck.cards.length) return;
  const card=deck.cards[Math.floor(Math.random()*deck.cards.length)];
  const text=propVal(card.props,'text',card.name);
  const effect=propVal(card.props,'effect','');
  const amount=propVal(card.props,'amount',0);
  const target=propVal(card.props,'target',null);

  // Apply effect
  const player=G.players[G.currentPlayer];
  const iconMap={heal:'💚',damage:'💔',pay:'💸',move_to:'🚀',transfer:'💰'};
  const icon=iconMap[effect]||'🃏';
  showCardPopup(card.name, text, effect, icon);

  if (effect==='heal') { player.hp=Math.min(100,player.hp+amount); addLog(`🃏 ${card.name}: +${amount} can`,'heal'); }
  else if (effect==='damage') { player.hp=Math.max(0,player.hp-amount); addLog(`🃏 ${card.name}: -${amount} can`,'damage'); }
  else if (effect==='pay') { player.money=Math.max(0,player.money-amount); addLog(`🃏 ${card.name}: -${amount}💰`,'damage'); }
  else if (effect==='transfer') { player.money+=amount; addLog(`🃏 ${card.name}: +${amount}💰`,'heal'); }
  else if (effect==='move_to') {
    if (target) {
      const idx=G.board.findIndex(t=>t.name===target||propVal(t.props,'type','')==='jail');
      if (idx>=0) { player.pos=idx; addLog(`🃏 ${card.name}: → ${G.board[idx].name}`,'event'); }
    }
  } else { addLog(`🃏 Kart çekildi: ${card.name}`,'event'); }

  renderBoard();
  renderPlayers();
}

function showCardPopup(title, text, effect, icon='🃏') {
  document.getElementById('cardIcon').textContent=icon||'🃏';
  document.getElementById('cardTitle').textContent=title;
  document.getElementById('cardText').textContent=text;
  document.getElementById('cardPopup').classList.add('show');
  document.getElementById('overlay').classList.add('show');
}

function closeCard() {
  document.getElementById('cardPopup').classList.remove('show');
  document.getElementById('overlay').classList.remove('show');
}

function resetGame() {
  if (!G) return;
  const code=document.getElementById('codeInput').value;
  if (code.trim()) parseAndBuild();
}

function switchTab(name) {
  document.querySelectorAll('.tab-btn').forEach((b,i)=>{
    const tabs=['players','log','deck'];
    b.classList.toggle('active',tabs[i]===name);
  });
  document.querySelectorAll('.tab-content').forEach(c=>{
    c.classList.toggle('active', c.id==='tab-'+name);
  });
}

function showError(msg) {
  const el=document.getElementById('errorBox');
  el.style.display='block'; el.textContent='❌ '+msg;
}
function hideError() {
  document.getElementById('errorBox').style.display='none';
}
function clearCode() {
  document.getElementById('codeInput').value='';
  document.getElementById('parseStatus').textContent='Henüz yüklenmedi';
}

